                    "type": "FILEPATH",
                    "value": "F:/vcpkg/scripts/buildsystems/vcpkg.cmake"
                },
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "debug",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
